rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Función para validar que el archivo es una imagen y pesa menos de 5MB
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') 
             && request.resource.size < 5 * 1024 * 1024;
    }

    match /posts/{postId}/{imageId} {
      // Cualquier usuario autenticado puede ver las imágenes
      allow read: if request.auth != null;
      // Solo usuarios autenticados pueden subir, y debe ser una imagen < 5MB
      allow write: if request.auth != null && isValidImage();
    }
  }
}