rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Carpeta de publicaciones
    match /posts/{fileName} {
      allow write: if request.auth != null 
                   // 1. Previene subida de archivos gigantes (Límite: 6MB)
                   && request.resource.size < 6 * 1024 * 1024
                   // 2. Lista blanca de formatos seguros mediante Regex
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
                   
      allow read: if request.auth != null;
    }
    
    // Carpeta de perfiles
    match /profiles/{userId} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 3 * 1024 * 1024 // 3MB para perfiles
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow read: if request.auth != null;
    }
  }
}