{
    "rules": {

        "centers": {
            ".read": "auth != null",
            ".indexOn": ["is_active"],
            "$center_id": {
                ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
                ".validate": "newData.hasChildren(['id', 'name', 'email_domains', 'boundary_coords', 'is_active'])"
            }
        },

        "users": {
            "$user_id": {
                ".write": "auth != null && auth.uid === $user_id && auth.token.email_verified === true",
                ".read": "auth != null && auth.token.email_verified === true",
                ".validate": "newData.hasChildren(['id', 'center_id', 'role', 'email', 'name', 'created_at', 'updated_at', 'is_deleted']) && newData.child('id').val() === $user_id",
                "role": {
                    ".validate": "(!data.exists() && newData.val() === 'student') || (data.exists() && newData.val() === data.val())"
                },
                "center_id": {
                    ".validate": "root.child('centers').child(newData.val()).exists()"
                }
            }
        },

        "posts": {
            ".read": "auth != null && auth.token.email_verified === true",
            ".indexOn": ["center_id", "type", "status", "category", "user_id", "created_at", "coords/geohash"],
            "$post_id": {
                ".write": "auth != null && auth.token.email_verified === true && (!data.exists() || data.child('user_id').val() === auth.uid)",
                ".validate": "newData.hasChildren(['id', 'user_id', 'center_id', 'type', 'title', 'category', 'status', 'created_at', 'updated_at', 'is_deleted'])",
                "user_id": {
                    ".validate": "!data.exists() || newData.val() === data.val()"
                }
            }
        },

        "post_views": {
            "$post_id": {
                ".indexOn": ["timestamp"],
                "$user_id": {
                    ".read": "auth != null && auth.token.email_verified === true && (auth.uid === $user_id || root.child('posts').child($post_id).child('user_id').val() === auth.uid)",
                    ".write": "auth != null && auth.token.email_verified === true && auth.uid === $user_id",
                    ".validate": "newData.hasChildren(['timestamp']) && newData.child('timestamp').isNumber() && newData.child('timestamp').val() <= now"
                }
            }
        },

        "chats": {
            ".indexOn": ["center_id", "post_id"],
            "$chat_id": {
                ".read": "auth != null && auth.token.email_verified === true && data.child('members').child(auth.uid).val() === true",
                ".write": "auth != null && auth.token.email_verified === true && (!data.exists() || data.child('members').child(auth.uid).val() === true)",
                ".validate": "newData.hasChildren(['id', 'center_id', 'post_id', 'members', 'created_at']) && newData.child('members').child(auth.uid).val() === true && newData.child('created_at').isNumber()"
            }
        },

        "messages": {
            "$chat_id": {
                ".read": "auth != null && auth.token.email_verified === true && root.child('chats').child($chat_id).child('members').child(auth.uid).val() === true",
                "$message_id": {
                    ".write": "auth != null && auth.token.email_verified === true && root.child('chats').child($chat_id).child('members').child(auth.uid).val() === true && !data.exists()",
                    ".validate": "newData.hasChildren(['id', 'sender_id', 'text', 'timestamp']) && newData.child('sender_id').val() === auth.uid && newData.child('text').isString() && newData.child('timestamp').isNumber() && newData.child('timestamp').val() <= now"
                }
            }
        }
    }
}